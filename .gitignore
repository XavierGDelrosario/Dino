# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# kuromoji dictionary, copied from node_modules at predev/prebuild (see setup:dict)
public/dict/

# Local env files (never commit secrets)
.env
.env.*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/

# Supabase local
supabase/.branches/
supabase/.temp/

# JMdict release files (downloaded for ingest; never committed)
jmdict-*.json
jmdict-*.json.tgz
jmdict-*.json.zip

# Japanese WordNet release files (downloaded for ingest:wordnet; never committed)
wnjpn.db
wnjpn*.tab
wnjpn*.gz

# Generated seed dump (JMdict + embeddings), ~120MB — regenerate with
# `npm run db:dump-seed` after an ingest/embed; auto-loaded on `db reset`.
supabase/seeds/

# Off-site logical backups of the irreplaceable user tables (npm run db:backup) —
# contains real user data; copy off the host, never commit.
backups/

# Capacitor iOS — the ios/ project IS committed (once generated), but these build
# artifacts are not: CocoaPods, the synced web copy, DerivedData, user state.
ios/App/Pods/
ios/App/App/public/
ios/App/build/
ios/DerivedData/
ios/capacitor-cordova-ios-plugins/
*.xcuserstate
.xcode.env.local
