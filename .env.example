# Frontend (Vite). The anon key is public — safe to expose; RLS protects data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Edge function secrets are NOT set here. Set them server-side with:
#   supabase secrets set TRANSLATION_API_KEY=...
# Optional: TRANSLATION_API_URL (defaults to the provider's endpoint).
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically.
