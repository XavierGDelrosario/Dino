# Frontend (Vite). The anon key is public — safe to expose; RLS protects data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Cloudflare Turnstile sitekey (public) — captcha on anonymous sign-in,
# password sign-in and password recovery, so a rotating-IP bot can't bloat auth.users.
# Unset = captcha off (today's behavior). Must be an INVISIBLE widget: the anonymous
# token is minted during bootstrap, where an interactive challenge would deadlock the
# first paint. The matching SECRET is a project setting, not an env var here — keep the
# two in step (see supabase/config.toml [auth.captcha] + src/services/captcha.ts).
# Local verify with Cloudflare's dummy keys (valid on any hostname, incl. localhost):
#   1x00000000000000000000BB = invisible, always passes
#   2x00000000000000000000BB = invisible, always fails (proves the reject path)
VITE_TURNSTILE_SITE_KEY=

# Edge function secrets are NOT set here. Set them server-side with:
#   supabase secrets set TRANSLATION_API_KEY=...   # a Google Cloud Translation API key
# The MT fallback (words JMdict lacks + whole-paragraph gloss) uses Google Cloud
# Translation v2; without the key it's disabled and the function is JMdict-only.
# Optional: TRANSLATION_API_URL overrides the Google v2 endpoint (proxy/mock).
# Optional: PARAGRAPH_CHAR_LIMIT — default max chars per paragraph translation
#   (per-request guard); a per-user `user_limits` row overrides it. Default 2000.
# Optional: MONTHLY_CHAR_QUOTA — default hard ceiling on chars translated per
#   calendar month per user (metered in translation_usage; the free-tier gate).
#   A per-user `user_limits` row overrides it. Default 450000 (margin under 500k).
# Optional (cost controls #1): MT_DISABLED=1 — emergency kill-switch, stop ALL paid
#   Google calls (JMdict-only) without a redeploy.
# Optional: GLOBAL_MONTHLY_CHAR_QUOTA — aggregate monthly char cap across ALL users
#   (metered in global_translation_usage). Unset = a built-in default (2,000,000)
#   applies, so spend is never fully unbounded; lower it in prod to taste.
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically.
#
# Local edge dev loads these from supabase/functions/.env (gitignored):
#   supabase functions serve translate --env-file supabase/functions/.env
