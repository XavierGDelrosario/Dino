{
  "name": "dino",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/integration",
    "predev": "npm run setup:dict",
    "prebuild": "npm run setup:dict",
    "setup:dict": "test -f public/dict/base.dat.gz || (mkdir -p public/dict && cp -R node_modules/kuromoji/dict/. public/dict/)",
    "ingest:jmdict": "tsx scripts/ingest-jmdict.ts",
    "ingest:wordnet": "tsx scripts/ingest-wordnet.ts",
    "ingest:english-frequency": "tsx scripts/ingest-english-frequency.ts",
    "build:leveling": "tsx scripts/build-leveling-profile.ts",
    "ingest:english-proficiency": "tsx scripts/ingest-english-proficiency.ts",
    "db:up": "bash scripts/supabase-up.sh",
    "db:dump-seed": "bash scripts/dump-seed.sh",
    "db:backup": "bash scripts/backup-user-data.sh",
    "db:restore-test": "bash scripts/restore-test.sh",
    "gen:types": "supabase gen types typescript --local > src/types/database.types.ts",
    "test:e2e": "bash scripts/e2e.sh",
    "smoke:prod": "node scripts/preflight-smoke.mjs",
    "ios:build": "bash scripts/build-ios.sh",
    "ios:build:staging": "DINO_ENV=staging bash scripts/build-ios.sh",
    "ios:sync": "cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@supabase/supabase-js": "^2.45.0",
    "fflate": "^0.8.3",
    "kuromoji": "^0.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/kuromoji": "^0.1.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "pg": "^8.21.0",
    "playwright": "^1.61.0",
    "supabase": "^2.107.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
