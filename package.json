{
  "name": "dino",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/integration",
    "predev": "npm run setup:dict",
    "prebuild": "npm run setup:dict",
    "setup:dict": "test -f public/dict/base.dat.gz || (mkdir -p public/dict && cp -R node_modules/kuromoji/dict/. public/dict/)",
    "ingest:jmdict": "tsx scripts/ingest-jmdict.ts",
    "db:dump-seed": "bash scripts/dump-seed.sh",
    "db:backup": "bash scripts/backup-user-data.sh",
    "db:restore-test": "bash scripts/restore-test.sh",
    "gen:types": "supabase gen types typescript --local > src/types/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "fflate": "^0.8.3",
    "kuromoji": "^0.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/kuromoji": "^0.1.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "pg": "^8.21.0",
    "playwright": "^1.61.0",
    "supabase": "^2.107.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
