{
  "name": "dino",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/integration",
    "predev": "npm run setup:dict",
    "prebuild": "npm run setup:dict",
    "setup:dict": "test -f public/dict/base.dat.gz || (mkdir -p public/dict && cp -R node_modules/kuromoji/dict/. public/dict/)"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "kuromoji": "^0.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/kuromoji": "^0.1.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "supabase": "^2.107.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
